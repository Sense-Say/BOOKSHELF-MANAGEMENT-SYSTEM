    {
        "id": "465db0d5da754808",
        "type": "function",
        "z": "c7c7edfb187eb3c2",
        "name": "Prepare SQL Fetch",
        "func": "// 1. Ignore if it's the whole table updating\nif (Array.isArray(msg.payload)) { return null; }\n\n// 2. Extract the ID from the row we clicked\nvar studentID = msg.payload.id; \n\n// 3. Command SQL to find full details for this student\nmsg.topic = \"SELECT * FROM students WHERE student_no = '\" + studentID + \"';\";\nmsg.payload = []; // Clear payload to prevent SQL errors\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
