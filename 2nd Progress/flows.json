    {
        "id": "39750c693fb27c3b",
        "type": "function",
        "z": "c7c7edfb187eb3c2",
        "name": "Log Stacker",
        "func": "// 1. Check if the database actually found the student\nif (msg.payload && msg.payload.length > 0) {\n    var student = msg.payload[0]; // The first match found\n    var list = flow.get(\"libraryTable\") || [];\n\n    // 2. Format the time\n    var phTime = new Date().toLocaleTimeString('en-US');\n\n    // 3. Create the row\n    var newEntry = {\n        \"time\": phTime,\n        \"name\": student.full_name,\n        \"id\": student.student_no,\n        \"status\": \"BORROWED\"\n    };\n\n    // 4. Stacking Logic\n    list.unshift(newEntry);\n    if (list.length > 5) { list.pop(); }\n    flow.set(\"libraryTable\", list);\n\n    // 5. Send list to table\n    msg.payload = list;\n    return msg;\n}\nreturn null; // Ignore if name not found in SQL",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 570,
        "y": 320,
        "wires": [
            [
                "c64abebd67c0cdc4"
            ]
        ]
    },
    {
        "id": "f0d4f4ef5cb85bbf",
        "type": "ui_template",
        "z": "c7c7edfb187eb3c2",
        "group": "674f291f745f124d",
        "name": "CV TEMPLATE",
        "order": 2,
        "width": "16",
        "height": "4",
        "format": "<div ng-if=\"msg.payload[0].full_name\" style=\"background: white; border-radius: 12px; padding: 30px; display: flex; gap: 30px; align-items: flex-start; color: #333;\">\n    <div style=\"flex: 0 0 200px;\">\n        <!-- Dynamic Photo -->\n        <img src=\"/{{msg.payload[0].student_no}}.jpg\" style=\"width: 200px; height: 200px; border-radius: 10px; border: 4px solid #800000; object-fit: cover;\">\n    </div>\n    <div style=\"flex: 1;\">\n        <h1 style=\"color: #800000; margin: 0; font-size: 2.5em; font-weight: bold;\">{{msg.payload[0].full_name}}</h1>\n        <div style=\"margin-top: 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 15px; font-size: 1.2em;\">\n            <p><strong>STUDENT NO:</strong> {{msg.payload[0].student_no}}</p>\n            <p><strong>COURSE:</strong> {{msg.payload[0].course}}</p>\n            <p><strong>AGE:</strong> {{msg.payload[0].age}}</p>\n            <p><strong>CONTACT:</strong> {{msg.payload[0].phone_number}}</p>\n        </div>\n    </div>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 640,
        "y": 400,
        "wires": [
            []
        ]
    },
    {
        "id": "aea84acc07e34451",
        "type": "ui_template",
        "z": "c7c7edfb187eb3c2",
        "group": "",
        "name": "Global Theme",
        "order": 0,
        "width": 0,
        "height": 0,
        "format": "<style>\n    /* 1. FORCE THE BACKGROUND GRADIENT */\n    body,\n    md-content,\n    #v-app,\n    .nr-dashboard-container {\n        background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%) !important;\n        background-color: transparent !important;\n    }\n\n    /* 2. PUP MAROON HEADER */\n    md-toolbar {\n        background-color: #800000 !important;\n        border-bottom: 2px solid #FFD700;\n    }\n\n    /* 3. GLASSMORPHISM CARDS */\n    .nr-dashboard-template,\n    .nr-dashboard-table {\n        background: rgba(255, 255, 255, 0.05) !important;\n        backdrop-filter: blur(10px);\n        border: 1px solid rgba(255, 255, 255, 0.1) !important;\n        border-radius: 15px !important;\n        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5) !important;\n    }\n\n    /* 4. MAKE TABLE ROWS CLICKABLE (Force Hand Cursor) */\n    .ui-table tbody tr {\n        cursor: pointer !important;\n        transition: background-color 0.3s;\n    }\n\n    .ui-table tbody tr:hover {\n        background-color: rgba(255, 215, 0, 0.2) !important;\n        /* Gold highlight */\n    }\n\n    /* Highlight the Student Name Column */\n    .ui-table tbody td:nth-child(2) {\n        color: #FFD700 !important;\n        font-weight: bold;\n    }\n</style>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "global",
        "className": "",
        "x": 100,
